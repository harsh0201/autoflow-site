{
  "version": 2,
  "builds": [
    {
      "src": "api/intake.py",
      "use": "@vercel/python"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/intake",
      "dest": "/api/intake.py"
    },
    {
      "src": "/intake",
      "dest": "/public/intake/index.html"
    },
    {
      "src": "/intake/",
      "dest": "/public/intake/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "/public/$1"
    }
  ]
}
